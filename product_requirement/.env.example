# FemCare Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# AWS
AWS_REGION=eu-west-1
AWS_PROFILE=femcare-dev

# Environment
ENVIRONMENT=dev

# Cognito
COGNITO_PATIENT_POOL_ID=
COGNITO_CLINICIAN_POOL_ID=
COGNITO_CLIENT_ID=

# KMS
KMS_KEY_ARN=

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5

# Frontend
VITE_API_URL=http://localhost:8000
